{
  "name": "@wagn/dafc",
  "version": "0.2.0",
  "description": "Dumb as Fuck Coding Tool - Glob-driven interactive chat CLI for exploring codebases.",
  "type": "module",
  "bin": {
    "dafc": "./dafc"
  },
  "scripts": {
    "build": "bun build ./src/cli.ts --compile --outfile dafc --external react-devtools-core",
    "dev": "bun run ./src/cli.ts",
    "prepublishOnly": "bun run build",
    "format": "bun run prettier --write ."
  },
  "dependencies": {
    "chokidar": "^3.6.0",
    "clipboardy": "^4.0.0",
    "dotenv": "^16.4.5",
    "env-paths": "^3.0.0",
    "fast-glob": "^3.3.2",
    "ignore": "^7.0.5",
    "ink": "^5.0.1",
    "openai": "^4.52.7",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^20.14.10",
    "@types/react": "^18.3.1",
    "prettier": "^3.8.1"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  },
  "files": [
    "dafc",
    "src/",
    "LICENSE",
    "README.md"
  ],
  "keywords": [
    "llm",
    "ai",
    "cli",
    "codegen",
    "context",
    "gemini",
    "openai",
    "developer-tool"
  ],
  "homepage": "https://github.com/AviSantoso/dafc",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AviSantoso/dafc.git"
  },
  "bugs": {
    "url": "https://github.com/AviSantoso/dafc/issues"
  },
  "author": "Avi Santoso",
  "license": "MIT"
}
